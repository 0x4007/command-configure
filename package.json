{
  "name": "plugin-template",
  "version": "1.0.0",
  "description": "Ubiquibot plugin template repository with TypeScript support.",
  "author": "Ubiquity DAO",
  "license": "MIT",
  "main": "src/worker.ts",
  "type": "module",
  "engines": {
    "node": ">=20.10.0"
  },
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "format": "run-p format:*",
    "check-formatting": "run-p check-formatting:* format:cspell",
    "check-formatting:lint": "eslint --fix-dry-run",
    "format:lint": "eslint --fix .",
    "format:prettier": "prettier --write .",
    "check-formatting:prettier": "prettier --check .",
    "format:cspell": "cspell **/*",
    "knip": "knip --config .github/knip.ts",
    "knip-ci": "knip --no-exit-code --reporter json --config .github/knip.ts",
    "prepare": "husky install",
    "test": "cross-env NODE_OPTIONS=\"$NODE_OPTIONS --experimental-vm-modules\" jest --setupFiles dotenv/config --coverage",
    "worker": "wrangler dev --env dev --port 4000"
  },
  "keywords": [
    "typescript",
    "template",
    "dao",
    "ubiquity",
    "open-source"
  ],
  "dependencies": {
    "@anthropic-ai/sdk": "0.27.3",
    "@octokit/auth-app": "7.1.4",
    "@octokit/rest": "21.0.2",
    "@sinclair/typebox": "0.32.33",
    "@types/jsonwebtoken": "9.0.8",
    "@ubiquity-os/plugin-sdk": "^2.0.1",
    "@ubiquity-os/ubiquity-os-logger": "^1.3.2",
    "dotenv": "16.4.4",
    "hono": "^4.6.16",
    "inquirer": "11.1.0",
    "js-yaml": "4.1.0",
    "jsonwebtoken": "9.0.2",
    "nodemon": "3.1.9",
    "simple-git": "3.27.0",
    "ts-node": "^10.9.2"
  },
  "devDependencies": {
    "@commitlint/cli": "18.6.1",
    "@commitlint/config-conventional": "18.6.2",
    "@cspell/dict-node": "4.0.3",
    "@cspell/dict-software-terms": "3.3.18",
    "@cspell/dict-typescript": "3.1.2",
    "@eslint/js": "9.5.0",
    "@jest/globals": "29.7.0",
    "@mswjs/data": "0.16.1",
    "@types/jest": "29.5.12",
    "@types/js-yaml": "4.0.9",
    "@types/node": "20.11.19",
    "@typescript-eslint/eslint-plugin": "7.0.1",
    "@typescript-eslint/parser": "7.0.1",
    "cross-env": "^7.0.3",
    "cspell": "8.4.0",
    "esbuild": "0.20.1",
    "eslint": "8.56.0",
    "eslint-config-prettier": "9.1.0",
    "eslint-plugin-check-file": "2.8.0",
    "eslint-plugin-filename-rules": "1.3.1",
    "eslint-plugin-prettier": "5.1.3",
    "eslint-plugin-sonarjs": "0.24.0",
    "husky": "9.0.11",
    "jest": "29.7.0",
    "jest-junit": "16.0.0",
    "jest-md-dashboard": "0.8.0",
    "knip": "5.0.1",
    "lint-staged": "15.2.2",
    "npm-run-all": "4.1.5",
    "prettier": "3.2.5",
    "ts-jest": "29.1.2",
    "tsx": "4.7.1",
    "typescript": "5.6.2",
    "typescript-eslint": "8.8.1",
    "wrangler": "3.102.0"
  },
  "lint-staged": {
    "*.ts": [
      "prettier --write",
      "eslint --fix"
    ],
    "src/**.{ts,json}": [
      "cspell"
    ]
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  }
}
